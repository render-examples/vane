# Render sets these in render.yaml. Override in the dashboard if needed.

NODE_ENV=production
# App root. Vane writes persistent data under $DATA_DIR/data (db.sqlite, config.json,
# uploads), which is the disk mounted at /home/vane/data. Do not set this to
# /home/vane/data or paths double-nest and the DB fails to open on first boot.
DATA_DIR=/home/vane
PORT=3000

# Bundled SearXNG (set in Dockerfile). Only change if you run the slim image
# with an external SearXNG private service.
# SEARXNG_API_URL=http://localhost:8080

# LLM and search provider keys are configured in the Vane setup UI after deploy,
# stored in SQLite on the persistent disk — not as Render env vars by default.
